{
  "name": "skill-smokeplanner",
  "version": "0.1.0",
  "description": "Generate local smoke plans from SKILL.md files and repo metadata.",
  "type": "module",
  "bin": {
    "skill-smokeplanner": "./bin/skill-smokeplanner.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check-package.js",
    "build": "node scripts/check-package.js",
    "smoke": "node bin/skill-smokeplanner.js plan fixtures/complete-skill/SKILL.md --json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "agent-skills",
    "smoke-test",
    "safety",
    "automation"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skill-smokeplanner.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skill-smokeplanner/issues"
  },
  "homepage": "https://github.com/rogerchappel/skill-smokeplanner#readme",
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
